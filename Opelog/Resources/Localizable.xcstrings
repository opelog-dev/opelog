    },
    "settings_privacy_combined_body" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deine Daten bleiben auf diesem Gerät.\nKein Konto nötig.\nOpelog beurteilt keine Produktsicherheit oder Haltbarkeit. Tage und Erinnerungen basieren auf deinen eigenen Einstellungen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your data stays on this device.\nNo account required.\nOpelog does not determine product safety or expiration. Days and reminders are based on your own settings."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tus datos se guardan en este dispositivo.\nNo se necesita cuenta.\nOpelog no determina la seguridad ni la caducidad de los productos. Los días y recordatorios se basan en tus propios ajustes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vos données restent sur cet appareil.\nAucun compte requis.\nOpelog ne détermine pas la sécurité ni la date d’expiration des produits. Les jours et rappels sont basés sur vos propres réglages."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Data Anda tetap di perangkat ini.\nTidak memerlukan akun.\nOpelog tidak menentukan keamanan atau kedaluwarsa produk. Hari dan pengingat mengacu pada pengaturan Anda sendiri."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I tuoi dati restano su questo dispositivo.\nNessun account richiesto.\nOpelog non stabilisce sicurezza o scadenza dei prodotti. Giorni e promemoria dipendono dalle tue impostazioni."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "データはこの端末内に保存されます。\nログインは必要ありません。\nOpelogは使用期限や安全性を判定するアプリではありません。表示される日数や通知は、ユーザー自身が設定した内容に基づきます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "데이터는 이 기기에만 저장됩니다.\n로그인은 필요하지 않습니다.\nOpelog은 제품의 안전성이나 사용 기한을 판단하지 않습니다. 표시되는 날짜와 알림은 사용자가 설정한 내용을 기반으로 합니다。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seus dados ficam neste aparelho.\nNão é preciso conta.\nO Opelog não define segurança nem validade do produto. Dias e lembretes vêm das suas próprias configurações."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ข้อมูลอยู่บนอุปกรณ์นี้เท่านั้น\nไม่จำเป็นต้องมีบัญชี\nOpelog ไม่ได้ประเมินความปลอดภัยหรือวันหมดอายุของผลิตภัณฑ์ จำนวนวันและการเตือนอิงการตั้งค่าของคุณ"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dữ liệu của bạn chỉ nằm trên thiết bị này.\nKhông cần tài khoản.\nOpelog không xác định độ an toàn hay hạn dùng sản phẩm. Số ngày và nhắc nhở dựa trên cài đặt của bạn."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您的数据仅保存在本设备。\n无需注册账号。\nOpelog 不判断产品是否安全或是否过期；天数与提醒均依据您的个人设置。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "資料只會儲存在此裝置上。\n不需要登入。\nOpelog 不會判斷產品安全性或有效期限。顯示的天數與提醒皆根據你自己的設定。"
          }
        }
      }
    },

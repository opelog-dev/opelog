    "finished_log_empty_subtitle" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn du einen Artikel erledigst, erscheint er hier mit kurzen Zusammenfassungen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When you finish an item, it will appear here with gentle summaries."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuando termines un artículo, aparecerá aquí con resúmenes sencillos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quand vous terminez un article, il apparaîtra ici avec de petits récapitulatifs."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Saat Anda menyelesaikan sebuah item, item itu akan muncul di sini bersama ringkasan singkatnya."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quando termini un elemento, apparirà qui con riepiloghi chiari."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使い終わったアイテムが、やさしいまとめと一緒に表示されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "사용을 마친 아이템이 여기에 부드러운 요약과 함께 표시됩니다。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quando você concluir um item, ele aparecerá aqui com resumos simples."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "เมื่อทำเครื่องหมายว่าใช้หมด รายการจะอยู่ที่นี่พร้อมสรุปสั้น ๆ"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Khi bạn đánh dấu đã xong một mặt hàng, mục đó sẽ xuất hiện tại đây cùng tóm tắt ngắn gọn."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "当您将某件物品标记为已用完时，它会出现在这里，并附有简要汇总。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用完的項目會與摘要一起顯示在此。"
          }
        }
      }
    },

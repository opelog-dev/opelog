          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dữ liệu của bạn chỉ nằm trên thiết bị này."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",

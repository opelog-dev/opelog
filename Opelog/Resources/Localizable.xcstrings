    "settings_premium_pitch" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Geöffnete Artikel entspannter festhalten.\nPremium schaltet unbegrenzte Artikel, keine Werbung, Designs und mehrere Fotos frei."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Log opened items more freely.\nPremium unlocks unlimited items, no ads, themes, and multiple photos."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Registra tus productos abiertos con más libertad.\nPremium desbloquea artículos ilimitados, sin anuncios, temas y varias fotos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enregistrez vos produits ouverts plus librement.\nPremium débloque les articles illimités, sans publicité, les thèmes et plusieurs photos."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Catat barang yang sudah dibuka dengan lebih nyaman.\nPremium membuka item tanpa batas, tanpa iklan, tema, dan beberapa foto per item."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Annota gli elementi aperti con più libertà.\nPremium sblocca elementi illimitati, niente pubblicità, temi e più foto."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "もっと自由に、開封日を記録。\nPremiumでアイテム無制限、広告なし、テーマ変更、複数写真が使えます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "개봉일을 더 자유롭게 기록하세요.\nPremium으로 아이템 무제한, 광고 없음, 테마, 여러 장의 사진을 사용할 수 있습니다。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Registre itens abertos com mais liberdade.\nO Premium libera itens ilimitados, sem anúncios, temas e várias fotos."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "บันทึกของที่เปิดใช้ได้สะดวกขึ้น\nPremium ปลดล็อกรายการไม่จำกัด ไม่มีโฆษณา ธีม และหลายรูปต่อรายการ"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ghi nhật ký mở đồ dùng thoải mái hơn.\nPremium mở khóa mặt hàng không giới hạn, không quảng cáo, chủ đề và nhiều ảnh."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "更自由地记录已开封物品。\n高级版解锁不限量物品、无广告、多主题与多图功能。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "更自由地記錄開封日期。\nPremium 可解鎖無限項目、無廣告、主題與多張照片。"
          }
        }
      }
    },

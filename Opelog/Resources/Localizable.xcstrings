    "settings_notifications_intro" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jeder Artikel hat einen eigenen Schalter für Erinnerungen. Hinweise nutzen deine Prüfschätzung und erscheinen an diesem Tag zur Standard-Erinnerungszeit unten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Each item has its own reminder toggle. Alerts use your check estimate and fire on that day at your default reminder time below."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada artículo tiene su propio interruptor. Las alertas usan tu estimación y se envían ese día a la hora predeterminada de abajo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chaque article a son interrupteur. Les alertes suivent votre rappel estimé, à l’heure par défaut ci-dessous ce jour-là."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Setiap item memiliki sakelar pengingat sendiri. Peringatan menggunakan perkiraan cek Anda dan akan muncul pada hari itu pada waktu pengingat bawaan di bawah."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ogni elemento ha il suo interruttore per i promemoria. Gli avvisi si basano sulla stima di controllo e arrivano quel giorno all'orario predefinito qui sotto."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "各アイテムで通知をオンにできます。下の通知時間に合わせ、チェック目安の日に届きます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "각 아이템마다 알림을 켤 수 있습니다. 아래에서 선택한 시간에 맞춰 확인 기준일에 전송됩니다。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada item tem seu próprio interruptor de lembrete. Os alertas usam sua estimativa de verificação e disparam nesse dia no horário padrão abaixo."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "แต่ละรายการเปิด/ปิดเตือนเองได้ แจ้งเตือนใช้กำหนดตรวจของคุณ และไปในเวลาเริ่มต้นที่ตั้งด้านล่าง"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mỗi mặt hàng có công tắc nhắc riêng. Cảnh báo dựa trên ngày dự kiến kiểm tra của bạn và được gửi vào đúng ngày theo giờ nhắc mặc định bên dưới."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每项物品可单独开启提醒。提醒依据您设定的自查预估，并在下方默认时间于当天发出。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每個項目可開啟提醒；會在你設定的檢查提醒日，依下方提醒時間送出。"
          }
        }
      }

    "NSCameraUsageDescription" : {
      "comment" : "Privacy - Camera Usage Description",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opelog nutzt die Kamera, damit du Fotos von Artikeln aufnehmen kannst, die du dir merken möchtest."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opelog uses the camera so you can take photos of items you want to remember."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opelog usa la cámara para que puedas hacer fotos de los artículos que quieres recordar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opelog utilise l’appareil photo pour vous permettre de prendre des photos des articles à mémoriser."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opelog memakai kamera agar kamu bisa memotret barang yang ingin kamu ingat."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opelog usa la fotocamera per permetterti di scattare foto degli articoli che vuoi ricordare."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opelogは、記録したいアイテムの写真を撮影するためにカメラを使用します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opelog은 기억하고 싶은 아이템의 사진을 촬영하기 위해 카메라를 사용합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Opelog usa a câmera para você tirar fotos dos itens que quer lembrar."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opelog ใช้กล้องเพื่อให้คุณถ่ายรูปสิ่งของที่อยากจดจำ"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opelog dùng camera để bạn chụp ảnh các món đồ muốn ghi nhớ."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opelog 使用相机，以便你拍摄想记录的物品照片。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opelog 會使用相機，讓你拍攝想記錄的項目照片。"
          }
        }
      }
    },
    "NSPhotoLibraryUsageDescription" : {
      "comment" : "Privacy - Photo Library Usage Description",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opelog nutzt deine Fotomediathek, damit du Fotos von Artikeln hinzufügen kannst, die du dir merken möchtest."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opelog uses your photo library so you can add photos of items you want to remember."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opelog usa tu biblioteca de fotos para que puedas añadir fotos de los artículos que quieres recordar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opelog utilise votre photothèque pour vous permettre d’ajouter des photos des articles à mémoriser."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opelog memakai pustaka foto agar kamu bisa menambahkan foto barang yang ingin kamu ingat."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opelog usa la tua libreria foto per permetterti di aggiungere foto degli articoli che vuoi ricordare."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opelogは、記録したいアイテムの写真を追加するために写真ライブラリを使用します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opelog은 기억하고 싶은 아이템의 사진을 추가하기 위해 사진 보관함을 사용합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Opelog usa sua biblioteca de fotos para você adicionar fotos dos itens que quer lembrar."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opelog ใช้คลังภาพเพื่อให้คุณเพิ่มรูปสิ่งของที่อยากจดจำ"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opelog dùng thư viện ảnh để bạn thêm ảnh các món đồ muốn ghi nhớ."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opelog 使用你的照片图库，以便添加想记录的物品照片。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opelog 會使用你的照片圖庫，以加入想記錄的項目照片。"
          }
        }
      }
    }
  },
  "version" : "1.0"
